{
  "name": "vibecards",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "clean": "pnpm dlx rimraf .next node_modules",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "vitest run --ui --open",
    "test:e2e": "playwright test --ui",
    "prepare": "husky",
    "load-env": "dotenv -e .env.local",
    "auth:generate": "pnpm run load-env -- pnpm dlx @better-auth/cli generate --output src/database/auth-schema.ts --config src/lib/auth.ts",
    "db:pull": "bun load-env drizzle-kit pull",
    "db:push": "bun load-env drizzle-kit push",
    "db:generate": "bun load-env drizzle-kit generate",
    "db:view": "bun load-env drizzle-kit studio"
  },
  "engines": {
    "bun": ">=1.1.56"
  },
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-avatar": "^1.1.11",
