{
  "name": "vibecards",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "clean": "pnpm dlx rimraf .next node_modules coverage playwright",
    "start": "next start",
    "lint": "oxlint",
    "format:check": "oxfmt --check",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "prepare": "husky",
    "load-env": "dotenv -e .env.local",
    "auth:generate": "pnpm run load-env -- pnpm dlx @better-auth/cli generate --output src/database/auth-schema.ts --config src/lib/auth.ts",
    "db:pull": "pnpm load-env drizzle-kit pull",
    "db:push": "pnpm load-env drizzle-kit push",
    "db:generate": "pnpm load-env drizzle-kit generate",
    "db:view": "pnpm load-env drizzle-kit studio"
  },
  "engines": {
    "node": "24.14"
  },
  "packageManager": "bun@1.3.12",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-form-nextjs": "^1.29.0",
    "@vercel/analytics": "^2.0.1",
    "better-auth": "^1.6.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "resend": "^6.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typewriter-effect": "^2.22.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.4",
      "@hono/node-server": ">=1.19.10"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-form-devtools": "^0.2.21",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-istanbul": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.10",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
