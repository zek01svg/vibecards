{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "dist/**"],
      "env": [
        "RESEND_API_KEY",
        "DATABASE_URL",
        "GOOGLE_GENERATIVE_AI_API_KEY",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET"
      ]
    },
    "lint": {
      "cache": true
    },
    "format:check": {
      "cache": true
    },
    "test:unit": {
      "cache": true
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": true
    },
    "db:generate": {
      "cache": false
    },
    "auth:generate": {
      "cache": false
    }
  }
}
