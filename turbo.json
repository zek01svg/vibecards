{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "dist/**"]
    },
    "lint": {
      "cache": true
    },
    "format:check": {
      "cache": true
    },
    "test:unit": {
      "cache": true
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": true
    },
    "db:generate": {
      "cache": false
    },
    "auth:generate": {
      "cache": false
    }
  }
}
