{
  "include": ["**/*.ts", "**/*.tsx", "vite.config.ts", "playwright.config.ts", "drizzle.config.ts"],
  "compilerOptions": {
    "target": "esnext",
    "jsx": "react-jsx",
    "module": "esnext",
    "paths": {
      "@/*": ["./src/*"],
      "next/*": ["./src/compat/next-*.ts", "./src/compat/next-*.tsx"]
    },
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
